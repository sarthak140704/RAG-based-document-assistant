# Copy this file to .streamlit/secrets.toml (local) OR paste its contents into
# Streamlit Community Cloud → App → Settings → Secrets.
#
# NEVER commit real secrets. .streamlit/secrets.toml is git-ignored.

# --- Recommended for the free tier (fast build, low memory, no torch) ---
EMBEDDING_BACKEND = "hashing"

# --- Optional: use a real LLM instead of the offline extractive answerer ---
# LLM_PROVIDER = "openai"
# LLM_MODEL = "gpt-4o-mini"
# OPENAI_API_KEY = "sk-..."
