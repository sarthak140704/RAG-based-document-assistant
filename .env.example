# Copy to .env and fill in as needed. All values have safe defaults.

# LLM provider: extractive | openai | azure | ollama
# 'extractive' needs no API key and works fully offline (great for demos).
LLM_PROVIDER=extractive
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings backend: st (sentence-transformers, best quality) |
#                     hashing (pure-numpy, fast, offline, no torch)
EMBEDDING_BACKEND=st
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HASHING_DIM=512

# Chunking (measured in words)
CHUNK_SIZE=200
CHUNK_OVERLAP=40

# Retrieval
TOP_K=4
# Drop retrieved chunks below this similarity score (0 = keep all).
# Suggested: ~0.2 for EMBEDDING_BACKEND=st, ~0.05 for hashing.
MIN_SCORE=0.0

# Retrieval mode: hybrid (BM25 keyword + dense vector, fused via RRF) | vector
RETRIEVAL_MODE=hybrid
# Candidates pulled from each retriever before fusion/re-ranking.
CANDIDATE_K=10
# Re-ranker: none | cross-encoder (cross-encoder needs sentence-transformers/torch)
RERANK=none
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
